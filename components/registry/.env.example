# WIP Registry Service - Environment Variables
# Copy this to .env.local for local development

# MongoDB Configuration
MONGO_PASSWORD=secret
MONGO_URI=mongodb://mongoadmin:secret@mongodb:27017/
DATABASE_NAME=wip_registry

# Authentication
# Generate a secure key for production: openssl rand -hex 32
MASTER_API_KEY=dev_master_key_change_in_production
AUTH_ENABLED=true

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=*
