# WIP Production Environment
# Copy to .env and edit the values marked CHANGE-ME before running docker compose up
#
# Minimum required changes:
#   1. API_KEY — set a secure random string
#   2. WIP_HOSTNAME — set to your machine's hostname or IP
#   3. WIP_POSTGRES_PASSWORD — set a secure password
#   4. WIP_FILE_STORAGE_SECRET_KEY — set a secure password

# =============================================================================
# HOSTNAME — your server's hostname as seen by browsers
# =============================================================================
WIP_HOSTNAME=CHANGE-ME-hostname.local

# =============================================================================
# API KEY — single master key used for all service-to-service auth
# =============================================================================
# wip-auth checks WIP_AUTH_LEGACY_API_KEY, MASTER_API_KEY, and API_KEY
# in that order. Setting API_KEY is sufficient — all three are derived from it.
API_KEY=CHANGE-ME-random-string

# =============================================================================
# AUTHENTICATION (OIDC via Dex)
# =============================================================================
WIP_AUTH_MODE=dual
WIP_AUTH_JWT_ISSUER_URL=https://CHANGE-ME-hostname.local:8443/dex
WIP_AUTH_JWT_JWKS_URI=http://wip-dex:5556/dex/keys
WIP_AUTH_JWT_AUDIENCE=wip-console

# =============================================================================
# CORS — must match the hostname browsers use
# =============================================================================
WIP_CORS_ORIGINS=https://CHANGE-ME-hostname.local:8443

# =============================================================================
# MONGODB
# =============================================================================
WIP_MONGO_URI=mongodb://wip-mongodb:27017/

# =============================================================================
# POSTGRESQL (reporting)
# =============================================================================
WIP_POSTGRES_USER=wip
WIP_POSTGRES_PASSWORD=CHANGE-ME-postgres-password
WIP_POSTGRES_DB=wip_reporting

# =============================================================================
# FILE STORAGE (MinIO)
# =============================================================================
WIP_FILE_STORAGE_ACCESS_KEY=wip-minio-root
WIP_FILE_STORAGE_SECRET_KEY=CHANGE-ME-minio-password
WIP_FILE_STORAGE_PUBLIC_ENDPOINT=https://CHANGE-ME-hostname.local:9000
