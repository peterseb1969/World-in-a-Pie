# WIP Pi Deployment Environment Variables
# Copy this to .env.pi and customize for your setup
#
# Two deployment modes:
#   1. Full (with Caddy/OIDC): Use docker-compose.infra.pi.yml
#   2. Minimal (API keys only): Use docker-compose.infra.pi.minimal.yml
#
# Usage (Full mode with OIDC):
#   cp .env.pi.example .env.pi
#   # Edit .env.pi with your hostname
#   podman-compose --env-file .env.pi -f docker-compose.infra.pi.yml up -d
#   # Start services with the same env file:
#   podman-compose --env-file ../../.env.pi -f docker-compose.dev.yml up -d
#
# Usage (Minimal mode, API keys only):
#   podman-compose -f docker-compose.infra.pi.minimal.yml up -d
#   # No .env.pi needed - uses defaults

# ============================================
# HOSTNAME CONFIGURATION
# ============================================

# Your Pi's hostname (used in OIDC issuer URL)
# Must match what browsers use to access the Pi
WIP_HOSTNAME=wip-dev-pi.local

# ============================================
# JWT/OIDC CONFIGURATION (for services)
# ============================================

# Auth mode: dual (API key + JWT), api_key_only, jwt_only, none
WIP_AUTH_MODE=dual

# JWT issuer URL (must match what Dex puts in tokens)
# For HTTPS via Caddy, use the external hostname
WIP_AUTH_JWT_ISSUER_URL=https://wip-dev-pi.local/dex

# JWKS URL for fetching signing keys
# Uses internal container network (faster, no TLS verification needed)
WIP_AUTH_JWT_JWKS_URI=http://wip-dex:5556/dex/keys

# JWT audience (must match staticClients in Dex config)
WIP_AUTH_JWT_AUDIENCE=wip-console

# ============================================
# CONSOLE OIDC CONFIGURATION
# ============================================

# Enable/disable OIDC login button in console
# Set to false for API-key-only deployments
VITE_OIDC_ENABLED=true

# OIDC Authority (Dex URL as seen by browser)
# Use /dex for proxy via Caddy, or full URL for direct access
VITE_OIDC_AUTHORITY=/dex

# Dex target for Vite proxy (container-to-container)
VITE_DEX_TARGET=http://wip-dex:5556

# OAuth2 client configuration
VITE_OIDC_CLIENT_ID=wip-console
VITE_OIDC_CLIENT_SECRET=wip-console-secret

# Display name for OIDC provider in login dialog
VITE_OIDC_PROVIDER_NAME=Dex
