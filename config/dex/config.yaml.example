# Dex OIDC Provider Configuration for WIP
#
# This is a lightweight OIDC provider for development and minimal deployments.
# Works over HTTP (no HTTPS required), uses ~20-50MB RAM.
#
# Test users:
#   admin@wip.local / admin123 (wip-admins group)
#   editor@wip.local / editor123 (wip-editors group)
#   viewer@wip.local / viewer123 (wip-viewers group)
#
# To get a token for testing:
#   curl -X POST http://localhost:5556/dex/token \
#     -d "grant_type=password&username=admin@wip.local&password=admin123" \
#     -d "client_id=wip-console&client_secret=wip-console-secret&scope=openid profile email"

# Issuer URL - this appears in JWT tokens and must match what services validate
# Using localhost so tokens work from browser and CLI without /etc/hosts changes
issuer: http://localhost:5556/dex

# Storage backend - SQLite for simplicity (file-based, no external DB needed)
storage:
  type: sqlite3
  config:
    file: /data/dex.db

# Web server configuration
web:
  http: 0.0.0.0:5556
  # Allow CORS for WIP Console (browser-based OIDC)
  # Include both HTTP (direct Vite) and HTTPS (via Caddy) origins
  allowedOrigins:
    - http://localhost:3000
    - http://localhost:3001
    - https://localhost:8443
    - https://localhost
    - https://127.0.0.1:8443
    - https://127.0.0.1

# Enable the password database for static users
enablePasswordDB: true

# Static users (for development and minimal deployments)
# Passwords are bcrypt hashed
staticPasswords:
  - email: admin@wip.local
    hash: "$2b$12$FU5QNFECeqot7P1G/G9/GuBXQTLgXylqATk8iiIlTjWESVZVBKqzy"
    username: admin
    userID: "admin-001"
  - email: editor@wip.local
    hash: "$2b$12$KyDkUF9JjxL5joJbaNTz3eGiV/yZF/DrSuGPmN0iHicjd1DKLcLPK"
    username: editor
    userID: "editor-001"
  - email: viewer@wip.local
    hash: "$2b$12$RBQB01brEKNINrWbCBkzlun8DaKzJVJH8PZ553.YLFYkU9kFlzq1a"
    username: viewer
    userID: "viewer-001"

# OAuth2 clients (applications that can request tokens)
staticClients:
  - id: wip-console
    name: WIP Console
    secret: wip-console-secret
    redirectURIs:
      # HTTP (direct Vite dev server)
      - http://localhost:3000/auth/callback
      - http://localhost:3000/auth/silent-renew
      # HTTPS (via Caddy reverse proxy)
      - https://localhost:8443/auth/callback
      - https://localhost:8443/auth/silent-renew
      - https://localhost/auth/callback
      - https://localhost/auth/silent-renew
    # Public client for SPA (PKCE flow)
    public: false

  # CLI/testing client for password grant
  - id: wip-cli
    name: WIP CLI
    secret: wip-cli-secret
    redirectURIs:
      - http://localhost:8080/callback
    # Enable password grant for testing
    public: false

# Token expiration settings
expiry:
  deviceRequests: "5m"
  signingKeys: "6h"
  idTokens: "24h"
  refreshTokens:
    validIfNotUsedFor: "720h"   # 30 days of inactivity
    absoluteLifetime: "2160h"   # 90 days max

# OAuth2 settings
oauth2:
  responseTypes: ["code", "token", "id_token"]
  skipApprovalScreen: true
  alwaysShowLoginScreen: false
  # Enable password grant for testing (not recommended for production)
  passwordConnector: local

# Connectors - external identity providers (optional, for future use)
# Uncomment to enable GitHub, Google, LDAP, etc.
# connectors:
#   - type: github
#     id: github
#     name: GitHub
#     config:
#       clientID: $GITHUB_CLIENT_ID
#       clientSecret: $GITHUB_CLIENT_SECRET
#       redirectURI: http://localhost:5556/dex/callback
#
#   - type: ldap
#     id: ldap
#     name: "Company LDAP"
#     config:
#       host: ldap.example.com:636
#       insecureNoSSL: false
#       bindDN: cn=admin,dc=example,dc=com
#       bindPW: admin

# Logging
logger:
  level: "info"
  format: "text"
