# WIP Profile: Raspberry Pi Minimal
#
# Minimal deployment for Pi with limited resources.
# No Caddy, Dex, or Mongo Express - API keys only.
# Saves ~80MB RAM compared to standard profile.
#
# Generated by scripts/setup.sh - modify via setup script, not directly

# Profile metadata
WIP_PROFILE=pi-minimal
WIP_PROFILE_DESCRIPTION="Pi minimal - API keys only, no OIDC"

# Hardware settings
WIP_HEALTH_CHECK_INTERVAL=10
WIP_HEALTH_CHECK_TIMEOUT=90

# Services to include
WIP_INCLUDE_MONGO_EXPRESS=false
WIP_INCLUDE_DEX=false
WIP_INCLUDE_CADDY=false
WIP_INCLUDE_MINIO=false

# MongoDB version (Pi 4 requires 4.4.x for ARMv8.0)
WIP_MONGODB_IMAGE=docker.io/library/mongo:4.4.18

# Auth defaults (API key only, no OIDC)
WIP_AUTH_MODE=api_key_only

# Console settings
VITE_OIDC_ENABLED=false
