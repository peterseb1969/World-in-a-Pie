# WIP Profile: Mac Development
#
# Full stack for Mac development with all services including Mongo Express.
# Optimized for development convenience with fast health checks.
#
# Generated by scripts/setup.sh - modify via setup script, not directly

# Profile metadata
WIP_PROFILE=mac
WIP_PROFILE_DESCRIPTION="Mac development with full stack"

# Hardware settings
WIP_HEALTH_CHECK_INTERVAL=3
WIP_HEALTH_CHECK_TIMEOUT=60

# Services to include
WIP_INCLUDE_MONGO_EXPRESS=true
WIP_INCLUDE_DEX=true
WIP_INCLUDE_CADDY=true
WIP_INCLUDE_MINIO=true
WIP_INCLUDE_INGEST_GATEWAY=true

# MongoDB version (Mac can use latest)
WIP_MONGODB_IMAGE=docker.io/library/mongo:7

# Auth defaults (can be overridden by network mode)
WIP_AUTH_MODE=dual
