# WIP Profile: Raspberry Pi Large (8GB+)
#
# Full deployment for Pi 5 8GB or larger.
# Includes all services including Mongo Express.
# Same as Mac profile but with Pi-compatible MongoDB.
#
# Generated by scripts/setup.sh - modify via setup script, not directly

# Profile metadata
WIP_PROFILE=pi-large
WIP_PROFILE_DESCRIPTION="Pi 5 8GB+ - full stack with Mongo Express"

# Hardware settings
WIP_HEALTH_CHECK_INTERVAL=3
WIP_HEALTH_CHECK_TIMEOUT=60

# Services to include
WIP_INCLUDE_MONGO_EXPRESS=true
WIP_INCLUDE_DEX=true
WIP_INCLUDE_CADDY=true
WIP_INCLUDE_MINIO=true
WIP_INCLUDE_INGEST_GATEWAY=true

# MongoDB version
# Pi 5 with 8GB can use MongoDB 5.x or 6.x (ARMv8.2+)
# Using 6.x for better performance while staying compatible
WIP_MONGODB_IMAGE=docker.io/library/mongo:6

# Auth defaults
WIP_AUTH_MODE=dual
