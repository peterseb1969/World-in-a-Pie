# WIP Profile: Development Minimal
#
# Minimal development deployment for any platform.
# No Caddy or Dex - API keys only.
# Useful for quick testing or CI environments.
#
# Generated by scripts/setup.sh - modify via setup script, not directly

# Profile metadata
WIP_PROFILE=dev-minimal
WIP_PROFILE_DESCRIPTION="Development minimal - API keys only"

# Hardware settings
WIP_HEALTH_CHECK_INTERVAL=5
WIP_HEALTH_CHECK_TIMEOUT=60

# Services to include
WIP_INCLUDE_MONGO_EXPRESS=true
WIP_INCLUDE_DEX=false
WIP_INCLUDE_CADDY=false
WIP_INCLUDE_MINIO=false

# MongoDB version (use latest for development)
WIP_MONGODB_IMAGE=docker.io/library/mongo:7

# Auth defaults (API key only, no OIDC)
WIP_AUTH_MODE=api_key_only

# Console settings
VITE_OIDC_ENABLED=false
