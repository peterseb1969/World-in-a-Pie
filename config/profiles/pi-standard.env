# WIP Profile: Raspberry Pi Standard
#
# Standard deployment for Pi 4 (2-4GB) or Pi 5.
# Includes Caddy and Dex for OIDC, but no Mongo Express.
# Good balance of features and resource usage.
#
# Generated by scripts/setup.sh - modify via setup script, not directly

# Profile metadata
WIP_PROFILE=pi-standard
WIP_PROFILE_DESCRIPTION="Pi standard - full stack without Mongo Express"

# Hardware settings
WIP_HEALTH_CHECK_INTERVAL=10
WIP_HEALTH_CHECK_TIMEOUT=90

# Services to include
WIP_INCLUDE_MONGO_EXPRESS=false
WIP_INCLUDE_DEX=true
WIP_INCLUDE_CADDY=true
WIP_INCLUDE_MINIO=true

# MongoDB version (Pi 4 requires 4.4.x for ARMv8.0)
WIP_MONGODB_IMAGE=docker.io/library/mongo:4.4.18

# Auth defaults
WIP_AUTH_MODE=dual
