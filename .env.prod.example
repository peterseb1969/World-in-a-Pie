# WIP Production Environment Variables
# Copy this to .env.prod and configure all required variables before deployment.
#
# IMPORTANT: Never commit .env.prod to version control!
#
# Usage:
#   cp .env.prod.example .env.prod
#   # Edit .env.prod with your production values
#   podman-compose --env-file .env.prod -f docker-compose.infra.prod.yml up -d

# ============================================
# REQUIRED: Storage Location
# ============================================
# Where all persistent data is stored (MongoDB, PostgreSQL, NATS, MinIO, etc.)
# Use absolute path for production
WIP_DATA_DIR=/opt/wip/data

# ============================================
# REQUIRED: Network Configuration
# ============================================
# Your server's hostname (used in OIDC issuer URL and TLS certificates)
# Must match what browsers/clients use to access the server
WIP_HOSTNAME=wip.example.com

# External ports (80 and 443 for standard web access)
WIP_HTTP_PORT=80
WIP_HTTPS_PORT=443

# ============================================
# REQUIRED: Authentication
# ============================================

# Auth mode: dual (recommended), api_key_only, jwt_only
WIP_AUTH_MODE=dual

# JWT issuer URL (must match what Dex puts in tokens)
# This should be the external HTTPS URL
WIP_AUTH_JWT_ISSUER_URL=https://wip.example.com/dex

# JWKS URL for fetching signing keys (internal network)
WIP_AUTH_JWT_JWKS_URI=http://wip-dex:5556/dex/keys

# JWT audience (must match staticClients in Dex config)
WIP_AUTH_JWT_AUDIENCE=wip-console

# Master API key for system-to-system authentication
# Generate with: openssl rand -hex 32
# Or use file-based secrets (see docker-compose.infra.prod.yml)
WIP_AUTH_LEGACY_API_KEY=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX_STRING

# ============================================
# Console OIDC Configuration
# ============================================
VITE_OIDC_ENABLED=true
VITE_OIDC_AUTHORITY=/dex
VITE_DEX_TARGET=http://wip-dex:5556
VITE_OIDC_CLIENT_ID=wip-console
VITE_OIDC_CLIENT_SECRET=CHANGE_THIS_TO_YOUR_CLIENT_SECRET
VITE_OIDC_PROVIDER_NAME=WIP Login

# ============================================
# Database Credentials (used if not using secrets files)
# ============================================
# Prefer using Docker secrets (files) over environment variables for production
# See docker-compose.infra.prod.yml for secret file setup

MONGO_ROOT_USER=wiproot
# MONGO_ROOT_PASSWORD is read from secret file

POSTGRES_USER=wip
POSTGRES_DB=wip_reporting
# POSTGRES_PASSWORD is read from secret file

MINIO_ROOT_USER=wipminio
# MINIO_ROOT_PASSWORD is read from secret file

# ============================================
# File Storage Configuration
# ============================================
WIP_FILE_STORAGE_ENABLED=true
WIP_FILE_STORAGE_TYPE=minio
WIP_FILE_STORAGE_ENDPOINT=http://wip-minio:9000
WIP_FILE_STORAGE_ACCESS_KEY=wipminio
# WIP_FILE_STORAGE_SECRET_KEY should be read from secret or set here
WIP_FILE_STORAGE_BUCKET=wip-attachments

# ============================================
# Resource Limits (adjust based on available RAM)
# ============================================
WIP_MONGODB_MEMORY_LIMIT=2G
WIP_POSTGRES_MEMORY_LIMIT=1G
WIP_NATS_MEMORY_LIMIT=512M
WIP_MINIO_MEMORY_LIMIT=512M
WIP_DEX_MEMORY_LIMIT=128M
WIP_CADDY_MEMORY_LIMIT=128M

# ============================================
# Image Tags (pin versions for reproducibility)
# ============================================
WIP_MONGODB_IMAGE_TAG=7
WIP_POSTGRES_IMAGE_TAG=16
WIP_NATS_IMAGE_TAG=2.10
WIP_MINIO_IMAGE_TAG=RELEASE.2024-01-16T16-07-38Z
WIP_DEX_IMAGE_TAG=v2.38.0
WIP_CADDY_IMAGE_TAG=2-alpine

# ============================================
# Service URLs (for inter-service communication)
# ============================================
REGISTRY_URL=http://wip-registry:8001
DEF_STORE_URL=http://wip-def-store:8002
TEMPLATE_STORE_URL=http://wip-template-store:8003
DOCUMENT_STORE_URL=http://wip-document-store:8004

# MongoDB connection (with authentication)
# Password will be read from secret file or environment
MONGODB_URI=mongodb://wiproot:CHANGE_THIS@wip-mongodb:27017

# PostgreSQL connection (with authentication)
POSTGRES_HOST=wip-postgres
POSTGRES_PORT=5432

# NATS connection
NATS_URL=nats://wip-nats:4222
