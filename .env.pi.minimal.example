# WIP Pi Minimal Deployment - API Keys Only
# Copy this to .env.pi.minimal for API-key-only deployments
#
# This mode runs without Caddy or Dex, using only API key authentication.
# Saves ~55MB RAM and simplifies setup.
#
# Usage:
#   cp .env.pi.minimal.example .env.pi.minimal
#   podman-compose --env-file .env.pi.minimal -f docker-compose.infra.pi.minimal.yml up -d
#   # Start services with the same env file:
#   podman-compose --env-file ../../.env.pi.minimal -f docker-compose.yml up -d --build

# ============================================
# AUTH CONFIGURATION
# ============================================

# API key only mode (no JWT/OIDC)
WIP_AUTH_MODE=api_key_only

# ============================================
# CONSOLE CONFIGURATION
# ============================================

# Disable OIDC login button (API keys only)
VITE_OIDC_ENABLED=false
