# Required: Anthropic API key for the query agent
ANTHROPIC_API_KEY=sk-ant-...

# WIP connection (stdio mode — local development)
MCP_PYTHON=/path/to/WorldInPie/.venv/bin/python
MCP_CWD=/path/to/WorldInPie
WIP_API_KEY=dev_master_key_for_testing

# WIP connection (remote mode — K8s/server)
# MCP_URL=http://wip-mcp-server:8007/mcp
# MCP_TRANSPORT=http

# OIDC authentication (optional — enables user login via Dex)
# Set OIDC_ISSUER to enable auth. Users are redirected to Dex login.
# OIDC_ISSUER=http://localhost:5556/dex
# OIDC_CLIENT_ID=wip-apps
# OIDC_CLIENT_SECRET=wip-apps-secret
# SESSION_SECRET=change-me-to-a-random-string

# App-level access control (optional — restricts which Dex groups can use this app)
# Comma-separated group names. Empty or unset = all authenticated users allowed.
# ALLOWED_GROUPS=wip-admins,clintrial-users

# Optional: restrict queries to a specific namespace
# WIP_NAMESPACE=myapp

# Optional: Claude model (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-sonnet-4-5-20241022

# Optional: session TTL in minutes (default: 30)
# SESSION_TTL_MINUTES=30

# Optional: max tool-call turns per question (default: 15)
# MAX_TURNS=15
