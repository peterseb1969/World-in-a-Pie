{"openapi":"3.1.0","info":{"title":"WIP Reporting Sync","description":"Syncs documents from MongoDB to PostgreSQL for reporting","version":"0.1.0"},"paths":{"/health":{"get":{"summary":"Health Check","description":"Health check endpoint.","operationId":"health_check_health_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HealthResponse"}}}}}}},"/api/reporting-sync/status":{"get":{"summary":"Get Sync Status","description":"Get current sync worker status.","operationId":"get_sync_status_api_reporting_sync_status_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/SyncStatus"}}}}}}},"/api/reporting-sync/metrics":{"get":{"summary":"Get Metrics","description":"Get comprehensive metrics for the sync service.\n\nIncludes:\n- Uptime and connection status\n- Event processing stats (processed, failed, rate)\n- NATS consumer info (pending messages, lag)\n- Processing latency statistics (min, max, avg, percentiles)\n- Per-template sync statistics\n- Error breakdown by type","operationId":"get_metrics_api_reporting_sync_metrics_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MetricsResponse"}}}}}}},"/api/reporting-sync/metrics/consumer":{"get":{"summary":"Get Consumer Metrics","description":"Get NATS consumer information.\n\nReturns details about the JetStream consumer including:\n- Pending messages (queue depth)\n- Acknowledgement pending count\n- Redelivered message count\n- Delivered message count","operationId":"get_consumer_metrics_api_reporting_sync_metrics_consumer_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"anyOf":[{"$ref":"#/components/schemas/ConsumerInfo"},{"type":"null"}],"title":"Response Get Consumer Metrics Api Reporting Sync Metrics Consumer Get"}}}}}}},"/api/reporting-sync/alerts":{"get":{"summary":"Get Alerts","description":"Get current alerts and alert configuration.\n\nReturns:\n- Current alert configuration (thresholds, webhook settings)\n- Active alerts (currently triggered)\n- Recently resolved alerts","operationId":"get_alerts_api_reporting_sync_alerts_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/AlertsResponse"}}}}}}},"/api/reporting-sync/alerts/config":{"put":{"summary":"Update Alert Config","description":"Update alert configuration.\n\nConfigure:\n- enabled: Enable/disable alert checking\n- check_interval_seconds: How often to check alert conditions\n- thresholds: Warning/critical thresholds for each alert type\n- webhook_url: Optional webhook for notifications\n- webhook_headers: Custom headers for webhook requests","operationId":"update_alert_config_api_reporting_sync_alerts_config_put","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AlertConfig"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/AlertConfig"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/reporting-sync/alerts/test":{"post":{"summary":"Test Alerts","description":"Manually trigger an alert check and return results.\n\nUseful for testing alert configuration without waiting for the check interval.","operationId":"test_alerts_api_reporting_sync_alerts_test_post","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"additionalProperties":true,"type":"object","title":"Response Test Alerts Api Reporting Sync Alerts Test Post"}}}}}}},"/api/reporting-sync/schema/{template_value}":{"get":{"summary":"Get Schema","description":"Get the PostgreSQL schema for a template.","operationId":"get_schema_api_reporting_sync_schema__template_value__get","parameters":[{"name":"template_value","in":"path","required":true,"schema":{"type":"string","title":"Template Value"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"type":"object","additionalProperties":true,"title":"Response Get Schema Api Reporting Sync Schema  Template Value  Get"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/reporting-sync/sync/batch/{template_value}":{"post":{"summary":"Trigger Batch Sync","description":"Trigger a batch sync for a specific template.\n\nThis fetches all documents for the template from Document Store\nand syncs them to PostgreSQL.\n\nArgs:\n    template_value: Template code to sync\n    force: Force re-sync even if table already has data\n    page_size: Number of documents to fetch per page (10-1000)","operationId":"trigger_batch_sync_api_reporting_sync_sync_batch__template_value__post","parameters":[{"name":"template_value","in":"path","required":true,"schema":{"type":"string","title":"Template Value"}},{"name":"force","in":"query","required":false,"schema":{"type":"boolean","default":false,"title":"Force"}},{"name":"page_size","in":"query","required":false,"schema":{"type":"integer","default":100,"title":"Page Size"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{"$ref":"#/components/schemas/BatchSyncResponse"}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/api/reporting-sync/sync/batch":{"post":{"summary":"Trigger Batch Sync All","description":"Trigger batch sync for all templates.\n\nThis fetches all templates and syncs their documents to PostgreSQL.\nTemplates with sync_enabled=false are skipped.","operationId":"trigger_batch_sync_all_api_reporting_sync_sync_batch_post","parameters":[{"